{
    "name": "n8n-nodes-ibmi-db2",
    "version": "0.1.0",
    "description": "n8n community node for DB2 for IBM i",
    "license": "MIT",
    "homepage": "",
    "keywords": [
        "n8n-community-node-package"
    ],
    "author": {
        "name": "Filippo Milesi",
        "email": "filippo.milesi@cms.it"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/nullmile/n8n-nodes-ibmi-db2.git"
    },
    "scripts": {
        "build": "n8n-node build",
        "build:watch": "tsc --watch",
        "dev": "n8n-node dev",
        "lint": "n8n-node lint",
        "lint:fix": "n8n-node lint --fix",
        "release": "n8n-node release",
        "prepublishOnly": "n8n-node prerelease",
        "dev:packaged": "bash ./scripts/start-packaged-test.sh"
    },
    "files": [
        "dist"
    ],
    "n8n": {
        "n8nNodesApiVersion": 1,
        "strict": true,
        "credentials": [
            "dist/credentials/IbmiDb2Api.credentials.js"
        ],
        "nodes": [
            "dist/nodes/IbmiDb2/IbmiDb2.node.js"
        ]
    },
    "devDependencies": {
        "@n8n/node-cli": "*",
        "eslint": "9.32.0",
        "prettier": "3.6.2",
        "release-it": "^19.0.4",
        "typescript": "5.9.2"
    },
    "peerDependencies": {
        "n8n-workflow": "*"
    },
    "dependencies": {
        "node-jt400": "^6.0.1"
    }
}
